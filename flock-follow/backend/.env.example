# Copy this file to `.env` (or otherwise export these variables) before
# running the server. Never commit real secrets.

# A long, random, unpredictable string. Generate one with e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Must be "false" (or unset) in any real deployment.
DJANGO_DEBUG=false

# Comma-separated list of hostnames this server will accept requests for.
DJANGO_ALLOWED_HOSTS=flock-follow.live
